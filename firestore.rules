rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES AUXILIARES DE SEGURANÇA ---
    
    // Verifica se o usuário está autenticado
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Obtém o documento de perfil do usuário logado
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Verifica se o usuário logado possui a role especificada
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // --- REGRAS POR COLEÇÃO ---

    // Coleção de Perfis de Usuários
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow delete: if hasRole('admin');
    }
    
    // Coleção de Categorias de Cursos
    match /categories/{categoryId} {
      allow read: if true; // Acesso público para o catálogo
      allow write: if hasRole('admin'); // Apenas admin gerencia
    }
    
    // Coleção de Cursos
    match /courses/{courseId} {
      allow read: if true; // Aberto ao catálogo público
      // Apenas admin ou professores podem criar/editar
      allow create, update: if hasRole('admin') || hasRole('teacher');
      allow delete: if hasRole('admin');
    }

    // Coleção de Módulos de Cursos
    match /modules/{moduleId} {
      allow read: if true; // Público
      allow write: if hasRole('admin') || hasRole('teacher');
    }

    // Coleção de Aulas (Lessons)
    match /lessons/{lessonId} {
      allow read: if true; // Regra aberta (player do aluno restringe localmente por matrícula)
      allow write: if hasRole('admin') || hasRole('teacher');
    }

    // Coleção de Matrículas e Progresso (Enrollments)
    match /enrollments/{enrollmentId} {
      // O aluno matriculado ou admin/professor do curso podem ler o progresso
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        hasRole('admin') || 
        hasRole('teacher')
      );
      // Apenas o próprio aluno se inscreve em um curso
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      // O próprio aluno atualiza suas aulas concluídas e progresso
      allow update: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        hasRole('admin')
      );
      allow delete: if hasRole('admin');
    }

    // Coleção de Certificados Emitidos
    match /certificates/{certificateId} {
      allow read: if true; // Página de verificação pública precisa ler certificados por código
      allow create, update: if isSignedIn(); // Alunos geram após progresso
      allow delete: if hasRole('admin');
    }
  }
}
